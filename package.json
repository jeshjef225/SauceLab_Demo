{
  "name": "saucedemo-bdd-playwright",
  "version": "1.0.0",
  "description": "BDD Cucumber Playwright automation for SauceDemo login scenarios",
  "scripts": {
    "test": "cucumber-js --require-module ts-node/register --require support/*.ts --require step-definitions/**/*.ts --format json:reports/cucumber_report.json",
    "report": "node reports/generate-html-report.js"
  },
  "devDependencies": {
    "@playwright/test": "^1.43.1",
    "@cucumber/cucumber": "^10.0.0",
    "typescript": "^5.0.0",
    "ts-node": "^10.9.1",
    "cucumber-html-reporter": "^6.0.0",
    "@types/node": "^20.0.0"
  }
}
